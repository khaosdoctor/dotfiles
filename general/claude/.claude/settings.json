{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(nvim:*)",
      "Read(**/Obsidian/**)",
      "Glob(**/Obsidian/**)",
      "Grep(**/Obsidian/**)",
      "Read(**/.claude/**)",
      "Glob(**/.claude/**)",
      "Grep(**/.claude/**)",
      "Bash(grep:*)",
      "Bash(ps:*)",
      "Bash(cat:*)",
      "Read",
      "Read(~/Documents/**)",
      "Read(~/.config/**)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git remote:*)",
      "Bash(git stash list:*)",
      "Bash(git tag:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(docker images:*)",
      "Bash(docker inspect:*)",
      "Bash(docker stats:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(npm list:*)",
      "Bash(npm ls:*)",
      "Bash(npm outdated:*)",
      "Bash(npm info:*)",
      "Bash(npm view:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)"
    ],
    "defaultMode": "default"
  },
  "model": "sonnet[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -qE '^\\s*(git |git$|/usr/bin/git )' && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"IMPORTANT: git commands hang due to mise/shell hooks. You MUST prefix git commands with: env -i HOME=$HOME PATH=/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin /usr/bin/git --no-pager\"}}' || true",
            "statusMessage": "Checking git command..."
          }
        ]
      },
      {
        "matcher": "Bash|WebFetch|Read|Grep|Agent|Task|mcp__plugin_context-mode_context-mode__ctx_execute|mcp__plugin_context-mode_context-mode__ctx_execute_file|mcp__plugin_context-mode_context-mode__ctx_batch_execute",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/plugins/cache/context-mode/context-mode/1.0.75/hooks/pretooluse.mjs"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -d \"$PWD/.git\" ] || [ -f \"$PWD/package.json\" ] || [ -f \"$PWD/Cargo.toml\" ] || [ -f \"$PWD/go.mod\" ] || [ -f \"$PWD/pom.xml\" ]; then echo '\n# Code Repository Detected - Explain Skill Loaded\n' && cat ~/.claude/skills/explain/SKILL.md | tail -n +4; fi"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/plugins/cache/context-mode/context-mode/1.0.75/hooks/sessionstart.mjs"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "telegram@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "context-mode@claude-context-mode": true
  },
  "extraKnownMarketplaces": {
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      },
      "autoUpdate": true
    }
  },
  "alwaysThinkingEnabled": true,
  "promptSuggestionEnabled": false,
  "voiceEnabled": true
}
